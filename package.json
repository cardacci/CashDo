{
	"dependencies": {
		"@expo-google-fonts/inter": "^0.4.2",
		"@expo-google-fonts/poppins": "^0.4.1",
		"@expo/metro-runtime": "~6.1.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"expo": "~54.0.33",
		"expo-font": "~14.0.11",
		"expo-status-bar": "~3.0.9",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-web": "^0.21.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@types/jest": "~29.5.14",
		"@types/react": "~19.1.0",
		"eslint": "^9.39.3",
		"eslint-config-expo": "~10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"husky": "^9.1.7",
		"jest": "~29.7.0",
		"jest-expo": "~54.0.17",
		"json-server": "^1.0.0-beta.9",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"typescript": "~5.9.2"
	},
	"homepage": "https://cardacci.github.io/CashDo",
	"main": "index.ts",
	"name": "cashdo",
	"private": true,
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": "eslint --fix",
		"*.{json,md}": "prettier --write"
	},
	"jest": {
		"preset": "jest-expo",
		"setupFiles": [
			"./src/__tests__/setup.ts"
		],
		"testMatch": [
			"**/src/__tests__/**/*.test.ts"
		]
	},
	"scripts": {
		"android": "expo start --android",
		"api": "json-server --watch db.json --port 3001",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"ios": "expo start --ios",
		"lint:fix": "eslint . --fix",
		"lint": "eslint .",
		"prepare": "husky",
		"start": "expo start",
		"test": "jest",
		"web": "expo start --web"
	},
	"version": "1.0.2"
}
